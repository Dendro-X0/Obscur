# Maintainer signing secrets — OPTIONAL; implementation deferred (2026-06-01)
# Copy to .env.signing.local only when ready — a partial key breaks tauri build signing.
# See docs/program/local-signing-strategy.md
# Unsigned desktop:delete this file and use pnpm desktop:package without .env.signing.local

# --- Desktop (Tauri updater minisign) ---
# Must match plugins.updater.pubkey in apps/desktop/src-tauri/tauri.conf.json
# Generate/recover per local-signing-strategy.md — never commit the private key file.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# --- Android (release APK / AAB) ---
# Keystore path outside the repo — see android-p1-signing-runbook.md
TAURI_ANDROID_KEYSTORE_PATH=
TAURI_ANDROID_KEYSTORE_PASSWORD=
TAURI_ANDROID_KEY_ALIAS=obscur
TAURI_ANDROID_KEY_PASSWORD=
