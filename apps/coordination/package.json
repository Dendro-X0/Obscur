{
  "name": "@obscur/coordination-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/coordination-dev.mjs",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node ../../scripts/coordination-dev.mjs --migrate-only",
    "db:purge-membership": "node ../../scripts/coordination-dev.mjs --migrate-only --file ./scripts/purge-membership-directory.sql"
  },
  "dependencies": {
    "@dweb/coordination-contracts": "workspace:*",
    "@dweb/crypto": "workspace:*",
    "@noble/curves": "^1.9.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}