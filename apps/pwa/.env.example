# Copy to .env.local for local development (not committed).
#
# Path B (managed_workspace) — required for workspace create/join:
NEXT_PUBLIC_COORDINATION_URL=http://127.0.0.1:8787
#
# W53 transport smoke + strict kernel desktop test (see docs/program/obscur-kernel-ui-desktop-test-checklist.md):
# NEXT_PUBLIC_OBSCUR_TRANSPORT_HOST_PUBLISH_AUTHORITY=1
# NEXT_PUBLIC_OBSCUR_TRANSPORT_HOST_PUBLISH_NETWORK=1
# Or use: pnpm dev:desktop:transport-smoke (sets these automatically)
#
# Conduit Mesh relay pool (C7b): default-on on desktop. Opt out to legacy enhanced pool:
# NEXT_PUBLIC_OBSCUR_CONDUIT_MESH_POOL=0
#
# Desktop shell builds: show intake UI while maintainer flag awaits G8 (Phase 6b).
# NEXT_PUBLIC_OBSCUR_VAULT_SAVE_FROM_CHAT=1
# NEXT_PUBLIC_OBSCUR_ALLOW_LEGACY=1
# Dev-only (ignored in production builds unless NEXT_PUBLIC_OBSCUR_ALLOW_WORKSPACE_DEV_ESCAPES=true):
# Membership directory tests without a local Nostr relay:
NEXT_PUBLIC_DEV_COORDINATION_ONLY_WORKSPACE=true
