# Copy to .env.local for local development (not committed).
#
# Path B (managed_workspace) — required for workspace create/join:
NEXT_PUBLIC_COORDINATION_URL=http://127.0.0.1:8787
#
# Dev-only (ignored in production builds unless NEXT_PUBLIC_OBSCUR_ALLOW_WORKSPACE_DEV_ESCAPES=true):
# Membership directory tests without a local Nostr relay:
NEXT_PUBLIC_DEV_COORDINATION_ONLY_WORKSPACE=true
