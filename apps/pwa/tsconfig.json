{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@dweb/transport-contracts": [
        "../../packages/dweb-transport-contracts/src/index.ts"
      ],
      "@dweb/transport-contracts/*": [
        "../../packages/dweb-transport-contracts/src/*"
      ],
      "@dweb/transport-team-relay": [
        "../../packages/dweb-transport-team-relay/src/index.ts"
      ],
      "@dweb/transport-team-relay/*": [
        "../../packages/dweb-transport-team-relay/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out"
  ]
}