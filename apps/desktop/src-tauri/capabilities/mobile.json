{
    "identifier": "mobile",
    "description": "Mobile specific capabilities",
    "windows": [
        "main"
    ],
    "permissions": [
        "deep-link:default",
        "allow-window-commands",
        "allow-tor-commands",
        "allow-misc-commands",
        "allow-relay-commands",
        "allow-wallet-commands",
        "allow-db-commands",
        {
            "identifier": "http:default",
            "allow": [
                { "url": "http://127.0.0.1:*" },
                { "url": "http://localhost:*" }
            ]
        },
        "upload:default",
        "notification:default",
        "core:event:default",
        "core:path:default",
        "core:webview:default"
    ]
}