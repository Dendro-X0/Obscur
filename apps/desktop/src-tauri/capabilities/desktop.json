{
    "identifier": "desktop",
    "windows": [
        "main",
        "profile-*"
    ],
    "permissions": [
        "core:default",
        "core:window:allow-start-dragging",
        "allow-window-commands",
        "allow-tor-commands",
        "allow-misc-commands",
        "allow-relay-commands",
        "allow-wallet-commands",
        "allow-db-commands",
        "shell:allow-kill",
        "shell:allow-open",
        {
            "identifier": "http:default",
            "allow": [
                { "url": "http://127.0.0.1:*" },
                { "url": "http://localhost:*" }
            ]
        },
        "upload:default",
        "notification:default",
        "fs:default",
        "fs:allow-mkdir",
        "fs:allow-write-file",
        "fs:allow-remove",
        "fs:scope-appdata-recursive",
        "fs:allow-temp-write-recursive",
        "dialog:default",
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "sidecar": "tor"
                }
            ]
        }
    ]
}
