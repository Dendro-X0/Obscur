{
  "name": "dweb-messenger",
  "private": true,
  "version": "0.9.2",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev:pwa": "pnpm -C apps/pwa dev",
    "dev:api": "pnpm -C apps/api dev",
    "dev:desktop": "pnpm -C apps/desktop dev",
    "build:pwa": "pnpm -C apps/pwa build",
    "build:api": "pnpm -C apps/api build",
    "build:desktop": "pnpm -C apps/desktop build",
    "lint:pwa": "pnpm -C apps/pwa lint",
    "docs:check": "node scripts/docs-check.mjs",
    "security:audit": "pnpm audit",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:integrity-check": "node scripts/check-release-source-integrity.mjs",
    "release:artifact-matrix-check": "node scripts/check-release-artifact-matrix.mjs",
    "release:artifact-version-contract-check": "node scripts/check-release-artifact-version-contract.mjs",
    "release:artifact-version-parity": "node scripts/check-release-artifact-version-parity.mjs",
    "release:ci-signal-check": "node scripts/check-release-ci-signals.mjs",
    "release:verify-tag": "node scripts/verify-release-tag.mjs",
    "release:test-pack": "node scripts/run-release-test-pack.mjs",
    "ci:local": "powershell -ExecutionPolicy Bypass -File scripts/local-ci.ps1",
    "probe:relay-nip": "node scripts/relay-nip-probe.mjs",
    "ci:scan:pwa": "node scripts/pwa-ci-scan.mjs",
    "ci:scan:pwa:head": "node scripts/pwa-ci-scan-head.mjs",
    "version:check": "node scripts/check-version-alignment.mjs",
    "version:sync": "node scripts/sync-versions.mjs",
    "version:bump": "node scripts/bump-version.js"
  }
}
